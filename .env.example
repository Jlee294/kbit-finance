NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TEST_VIEWER_PW=your-viewer-test-password

# ── Phase 10: Google Drive + Sheets ────────────────────────────────────────────
# Service Account từ Google Cloud Console (IAM > Service Accounts > Keys > JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=kbit-finance@your-project.iam.gserviceaccount.com
# Dán private_key từ JSON key — giữ nguyên \\n (hoặc dùng \n thật nếu multi-line)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...key...\n-----END PRIVATE KEY-----\n"
# ID thư mục gốc trên Drive (lấy từ URL: drive.google.com/drive/folders/THIS_ID)
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-drive-folder-id
# ID spreadsheet Google Sheets (lấy từ URL: docs.google.com/spreadsheets/d/THIS_ID/edit)
GOOGLE_SHEET_ID=your-spreadsheet-id

# ── Phase 10: Notifications ────────────────────────────────────────────────────
# Telegram Bot (@BotFather để tạo bot)
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# Chat ID: group (-100...) hoặc user ID (dùng @userinfobot để lấy)
TELEGRAM_CHAT_ID=-1001234567890
# Zalo OA (https://developers.zalo.me/oa)
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-access-token

# ── Phase 10: Email (Resend) ────────────────────────────────────────────────────
# Đăng ký tại https://resend.com — verify domain kbitassociation.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=KBIT Finance <noreply@kbitassociation.com>
# Danh sách email nhận cảnh báo, cách nhau bằng dấu phẩy
ALERT_EMAIL_RECIPIENTS=cfo@kbitassociation.com,accounting@kbitassociation.com

# ── Phase 10: Cron security ────────────────────────────────────────────────────
# Header bảo vệ các endpoint cron (x-cron-secret: VALUE)
CRON_SECRET=your-random-secret-here
